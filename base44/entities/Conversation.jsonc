{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "conversation_key": {
      "type": "string",
      "description": "Deterministic unique key built from the two participant emails"
    },
    "participant_emails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Emails of participants"
    },
    "participant_names": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Display names of participants"
    },
    "last_message": {
      "type": "string",
      "description": "Preview of last message"
    },
    "last_message_date": {
      "type": "string",
      "format": "date-time",
      "description": "When last message was sent"
    },
    "hidden_for": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Emails of users who have hidden this conversation"
    }
  },
  "required": [
    "conversation_key",
    "participant_emails"
  ]
}